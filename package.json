{
  "name": "nextjs-ci-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "deps:baseline:freeze:deprecations": "node scripts/ci/npm-ci-deprecations-baseline.mjs freeze && npx prettier --write ci-baselines/deprecations.json",
    "deps:baseline:check:deprecations": "node scripts/ci/npm-ci-deprecations-baseline.mjs check",
    "deps:baseline:freeze:audit": "node scripts/ci/npm-audit-baseline.mjs freeze && npx prettier --write ci-baselines/audit.json",
    "deps:baseline:check:audit": "node scripts/ci/npm-audit-baseline.mjs check",
    "ci:all": "bash scripts/ci/all.sh",
    "ci:fast": "bash scripts/ci/fast.sh"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
